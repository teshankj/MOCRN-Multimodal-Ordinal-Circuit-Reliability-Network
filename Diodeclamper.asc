Version 4.1
SHEET 1 1348 2616
TEXT -80 24 Left 2 !* Diode Clamper Circuit - FIXED for Unique Runs\n* Compatible with LTspice syntax limitations\n \n.param Vin_freq = 1k\n \n* Multi-dimensional fault space\n.step param FT list 0 1 2 3 4            ; 5 fault types\n.step param DEG 0 100 20                  ; 6 degradation levels\n.step param run 1 50 1                    ; 50 unique runs\n \n* Remove problematic .options seed line - not needed with deterministic variation\n.options numdgt=9\n \n* Degradation factor\n.param D_prog = {DEG}/100\n \n* ============================================================================\n* DETERMINISTIC VARIATION (Monte Carlo Replacement)\n* Each run gets unique component values without using mc() or seed\n* ============================================================================\n \n* Primary variation functions (different frequencies ensure independence)\n.param var_c1 = 0.1 * sin(run * 0.6283)\n.param var_esr = 0.15 * cos(run * 1.2566)\n.param var_rload = 0.05 * sin(run * 1.8850)\n.param var_vin = 0.05 * cos(run * 2.5133)\n.param var_diode_is = 0.2 * sin(run * 3.1416)\n.param var_diode_rs = 0.1 * cos(run * 3.7699)\n.param var_diode_n = 0.05 * sin(run * 4.3982)\n \n* Secondary variation for more diversity\n.param var2_c1 = 0.05 * cos(run * 0.7854)\n.param var2_rload = 0.03 * sin(run * 1.5708)\n.param var2_vin = 0.02 * cos(run * 2.3562)\n \n* ============================================================================\n* CIRCUIT WITH FAULT INJECTION + VARIATION\n* ============================================================================\n \n* INPUT VOLTAGE (FT4 = voltage source degradation)\n.param Vin_amp_base = if(FT==4, 10*(1-0.3*D_prog), 10)\n.param Vin_amp_varied = Vin_amp_base * (1 + var_vin + var2_vin)\nV1 Vin 0 SINE(0 {Vin_amp_varied} {Vin_freq})\n \n* CLAMPING CAPACITOR (FT1 = capacitor degradation)\n.param C1_base = if(FT==1, 1u*(1-0.6*D_prog), 1u)\n.param C1_final = C1_base * (1 + var_c1 + var2_c1)\nC1 Vin N001 {C1_final}\n \n* CAPACITOR ESR (increases with FT1 degradation)\n.param ESR_C1_base = if(FT==1, 0.1*(1+20*D_prog), 0.1)\n.param ESR_C1_final = ESR_C1_base * (1 + var_esr)\nResr_C1 N001 N002 {ESR_C1_final}\n \n* CLAMPING DIODE (FT2 = diode degradation)\n.param D1_Is_base = if(FT==2, 2.52n*(1+100*D_prog), 2.52n)\n.param D1_Rs_base = if(FT==2, 0.568*(1+5*D_prog), 0.568)\n.param D1_N_base = if(FT==2, 1.752*(1+0.3*D_prog), 1.752)\n \n.param D1_Is_final = D1_Is_base * (1 + var_diode_is)\n.param D1_Rs_final = D1_Rs_base * (1 + var_diode_rs)\n.param D1_N_final = D1_N_base * (1 + var_diode_n)\n \n.model D1_fault D(IS={D1_Is_final} RS={D1_Rs_final} N={D1_N_final} CJO=4p VJ=0.4 M=0.4 TT=20n)\nD1 0 N002 D1_fault\n \n* LOAD RESISTOR (FT3 = resistor degradation)\n.param Rload_base = if(FT==3, 10k*(1+0.6*D_prog), 10k)\n.param Rload_final = Rload_base * (1 + var_rload + var2_rload)\nRload N002 0 {Rload_final}\n \n* ============================================================================\n* ANALYSIS\n* ============================================================================\n.tran 0 40ms 0 100u\n \n* Save waveforms\n.save V(Vin)\n.save V(N001)\n.save V(N002)\n.save I(Rload)\n.save I(V1)\n.save I(D1)\n \n.backanno\n.end
