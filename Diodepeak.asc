SHEET 1 1396 2552
TEXT -32 16 Left 2 !* Diode Peak Detector - Progressive Fault Injection Model - FIXED\n* Captures and holds peak voltage of input signal\n* Monte Carlo replaced with deterministic variation\n \n.param Vin_freq = 1k\n.param damage_steps = 100\n \n* Multi-dimensional fault space\n.step param FT list 0 1 2 3 4            ; 5 fault types\n.step param DEG 0 100 20                  ; 6 degradation levels\n.step param run 1 2 1                    ; 50 unique runs per combination\n \n.param D_prog = {DEG}/100\n \n* ============================================================================\n* DETERMINISTIC VARIATION (Replaces mc() Monte Carlo)\n* ============================================================================\n.param var_diode_is = 0.2 * sin(run * 0.6283)     ; ±20% for diode Is\n.param var_diode_rs = 0.1 * cos(run * 1.2566)     ; ±10% for diode Rs\n.param var_diode_n = 0.05 * sin(run * 1.8850)     ; ±5% for ideality\n.param var_cap = 0.1 * cos(run * 2.5133)          ; ±10% for capacitor\n.param var_esr = 0.15 * sin(run * 3.1416)         ; ±15% for ESR\n.param var_res = 0.05 * cos(run * 3.7699)         ; ±5% for resistors\n.param var_leak = 0.2 * sin(run * 4.3982)         ; ±20% for leakage\n \n* ============================================================================\n* Fault Type Definitions:\n* FT0: Normal operation\n* FT1: Hold capacitor degradation (leakage, reduced capacitance)\n* FT2: Detector diode degradation (high leakage, resistance)\n* FT3: Discharge resistor degradation (value drift)\n* FT4: Series resistor degradation (increased resistance)\n* ============================================================================\n \n* Input voltage (clean sine wave for testing)\nV1 Vin 0 SINE(0 10 {Vin_freq})\n \n* SERIES RESISTOR with fault injection + variation\n.param Rs_base = if(FT==4, 100*(1+0.8*D_prog), 100)\n.param Rs_val = Rs_base * (1 + var_res)\nRs Vin N001 {Rs_val}\n \n* DETECTOR DIODE with fault injection + variation\n* CORRECT: 2.5 decades (316×) for signal diode\n.param D1_Is_healthy = 2.52n\n.param D1_Is_degraded = 800n  ; 316× increase\n.param Is_decades = 2.5\n \n.param D1_Is_base = if(FT==2,\n+    {D1_Is_healthy * pow(10, Is_decades*D_prog)},\n+    D1_Is_healthy)\n \n.param D1_Rs_base = if(FT==2, 0.568*(1+5*D_prog), 0.568)\n.param D1_N_base = if(FT==2, 1.752*(1+0.3*D_prog), 1.752)\n \n.param D1_Is = D1_Is_base * (1 + var_diode_is)\n.param D1_Rs = D1_Rs_base * (1 + var_diode_rs)\n.param D1_N = D1_N_base * (1 + var_diode_n)\n \n.model D1_fault D(IS={D1_Is} RS={D1_Rs} N={D1_N} CJO=4p VJ=0.4 M=0.4 TT=20n)\nD1 N001 N002 D1_fault\n \n* HOLD CAPACITOR with fault injection + variation\n.param C1_base = if(FT==1, 10u*(1-0.5*D_prog), 10u)\n.param ESR_C1_base = if(FT==1, 0.1*(1+15*D_prog), 0.1)\n \n \n.param C1_val = C1_base * (1 + var_cap)\n.param ESR_C1 = ESR_C1_base * (1 + var_esr)\n \nC1 N002 N003 {C1_val}\nResr_C1 N003 0 {ESR_C1}\n \n* DISCHARGE RESISTOR with fault injection + variation\n.param Rd_base = if(FT==3, 100k*(1+0.6*D_prog), 100k)\n.param Rd_val = Rd_base * (1 + var_res)\nRd N002 0 {Rd_val}\n \n* ============================================================================\n* Analysis\n* ============================================================================\n.tran 0 4ms 0 10u\n.options numdgt=9\n \n* Save all critical waveforms\n.save V(Vin)          ; Input voltage\n.save V(N002)         ; Detected peak voltage (output)\n.save I(Rd)           ; Discharge resistor current\n \n.backanno\n.end
