TEXT -40 16 Left 2 !* Combined Progressive + Binary Fault Model - FIXED\n* Voltage Rectifier with Multiple Fault Types\n* Monte Carlo replaced with deterministic variation\n \n.param Vin_freq = 50\n.param damage_steps = 100\n \n* Multi-dimensional fault space\n.step param FT list 0 1 2 3 4 5          ; 6 fault types\n.step param DEG 0 100 20                  ; 6 degradation levels\n.step param run 1 2 1                    ; 50 unique runs per combination\n \n* Progressive damage factor\n.param D_prog = {DEG}/100\n \n* ============================================================================\n* DETERMINISTIC VARIATION (Replaces mc() Monte Carlo)\n* ============================================================================\n.param var1 = 0.2 * sin(run * 0.6283)     ; ±20% for diode Is\n.param var2 = 0.1 * cos(run * 1.2566)     ; ±10% for Rs, R, C, ESR\n.param var3 = 0.05 * sin(run * 1.8850)    ; ±5% for Vin\n.param var4 = 0.1 * cos(run * 2.5133)     ; ±10% for secondary variation\n.param var5 = 0.1 * sin(run * 3.1416)     ; ±10% for Rshunt\n \n* ============================================================================\n* Fault Type Definitions:\n* FT0: Normal operation (healthy circuit)\n* FT1: Diode catastrophic failure (high leakage + resistance)\n* FT2: Load resistor fault (reduced resistance)\n* FT3: Voltage source degradation (reduced amplitude)\n* FT4: Capacitor + ESR degradation (reduced C, increased ESR)\n* FT5: Shunt path fault (low resistance shunt)\n* ============================================================================\n \n* Component parameters with progressive faults + variation\n* CORRECT: 5 decades (100,000×) for power rectifier\n.param D_Is_healthy = 1e-14\n.param D_Is_catastrophic = 1e-9\n.param Is_decades = 5.0\n \n.param D_Is_base = if(FT==1,\n+    {D_Is_healthy * pow(10, Is_decades*D_prog)},\n+    {D_Is_healthy * (1 + 0.2*D_prog)})\n.param D_Is = D_Is_base * (1 + var1)\n \n.param D_Rs_base = if(FT==1, 10, 0.5*(1+3*D_prog))\n.param D_Rs = D_Rs_base * (1 + var2)\n \n.param Rload_base = if(FT==2, 100, 1k*(1+0.1*D_prog))\n.param Rload_val = Rload_base * (1 + var2)\n \n.param Vin_base = if(FT==3, 2, 10*(1-0.05*D_prog))\n.param Vin_amp = Vin_base * (1 + var3)\n \n.param C_base = if(FT==4, 47u, 470u*(1-0.4*D_prog))\n.param C_val = C_base * (1 + var2 + var4*0.5)\n \n.param ESR_base = if(FT==4, 5, 0.1*(1+4*D_prog))\n.param ESR_val = ESR_base * (1 + var2)\n \n.param Rshunt_base = if(FT==5, 100, 1Meg)\n.param Rshunt_val = Rshunt_base * (1 + var5)\n \n* ============================================================================\n* Circuit Implementation\n* ============================================================================\nVin in 0 SIN(0 {Vin_amp} {Vin_freq})\nRload n1 n2 {Rload_val}\nResr n1 tmp {ESR_val}\nC1 tmp n2 {C_val}\nRsh in n1 {Rshunt_val}\n \n.model Dmod D(Is={D_Is} Rs={D_Rs} N=1.9)\nD1 in n1 Dmod\nD2 0 n1 Dmod  \nD3 n2 in Dmod\nD4 n2 0 Dmod\n \n* ============================================================================\n* Analysis\n* ============================================================================\n.tran 0 40m 0 100u\n.options numdgt=9\n \n* Save all critical nodes\n.save V(in)           ; Input voltage\n.save V(n1)           ; After bridge rectifier\n.save V(n2)           ; Filtered output\n.save I(Rload)        ; Load current\n.save I(C1)           ; Capacitor current\n.save I(D1)           ; Diode current\n \n.backanno\n.end
